# Copy to .env (kept out of git) or supply via your secret manager.
# Never commit real values.

# Wave personal full-access token. Create at the Wave Developer Portal
# (developer.waveapps.com) -> your application -> Full Access Token.
# Using your own account's token is free even on the Starter/free plan.
WAVE_FULL_ACCESS_TOKEN=

# Optional -- substring of the business the tools default to.
# If unset, the first non-personal business on the account is used.
WAVE_BUSINESS_NAME=
